# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# Dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Package managers / logs
/.npm/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log

# Testing
/coverage
/.nyc_output
/playwright-report
/test-results
/e2e/
/tests/e2e/
/tests/**/*.spec.ts-snapshots/
/tests/**/*-snapshot*.png
/tests/**/*-snapshot*.jpg
/tests/**/*-snapshot*.jpeg
/tests/**/*-snapshot*.webp

# Next.js
/.next/
/out/

# Production
/build
/dist

# Environment files (can opt-in for committing if needed)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Vercel
.vercel

# TypeScript
*.tsbuildinfo
next-env.d.ts

# IDE - VS Code
.vscode/
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.code-workspace

# IDE - Sublime Text
*.tmlanguage.cache
*.tmPreferences.cache
*.stTheme.cache

# IDE - Other
.idea/
*.swp
*.swo
*~
.project
.classpath
.c9/
*.launch
.settings/

# OS
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini
*.app

# Certificates / keys
*.pem

# Temporary files
*.tmp
*.temp
*.bak
.#*

# AI assistant and agent context (not required for deploy)
AGENTS.md
CLAUDE.md
.github/copilot-instructions.md

# Local operational artifacts (not required for deploy)
tmp/
build_output.txt
playwright.config.ts
package-lock.json
package-lock.json
